# ============================================
# PRDS 环境变量模板
# 复制为 .env 并修改对应值
# ============================================

# ── 应用配置 ──────────────────────────────
APP_ENV=development          # 运行环境: development / production
APP_DEBUG=true               # 调试模式（开启后显示 /docs 接口文档）
APP_SECRET_KEY=change-me-in-production  # 应用密钥，生产环境必须更换

# ── PostgreSQL 数据库 ─────────────────────
POSTGRES_HOST=127.0.0.1      # 全合一容器内使用 127.0.0.1
POSTGRES_PORT=5432           # 数据库端口
POSTGRES_USER=prds           # 数据库用户名
POSTGRES_PASSWORD=prds_secret  # 数据库密码，生产环境必须更换
POSTGRES_DB=prds             # 数据库名称

# ── Redis 缓存与队列 ─────────────────────
REDIS_HOST=127.0.0.1         # 全合一容器内使用 127.0.0.1
REDIS_PORT=6379              # Redis 端口
REDIS_DB=0                   # Redis 数据库编号

# ── PanSou 搜索服务 ──────────────────────
PANSOU_BASE_URL=http://pansou-api:8888  # PanSou 容器名 + 端口（同一 Docker 网络内通信）

# ── Worker 异步任务 ──────────────────────
DELETE_DELAY_MINUTES=20      # 资源删除延迟（分钟），创建后多久执行删除
RESOURCE_TTL_MINUTES=10      # 资源有效期（分钟），分享链接的存活时间

# ── 缓存配置 ──────────────────────────────
SEARCH_CACHE_TTL=300         # 搜索结果缓存秒数（5分钟），相同关键词直接返回
RESOURCE_CACHE_TTL=600       # 已转存资源缓存秒数（10分钟），命中后毫秒级响应

# ── 业务默认值 ────────────────────────────
DEFAULT_PAN_TYPE=quark       # 默认网盘类型（用户未指定时使用）: quark / baidu / aliyun
DEFAULT_SEARCH_LIMIT=5       # 默认返回最新的前N条资源（按时间降序）
MAX_SEARCH_LIMIT=20          # 前端可请求的最大数量上限

# ── 管理后台 ──────────────────────────────
ADMIN_PASSWORD=admin789      # 管理后台登录密码，生产环境必须更换
